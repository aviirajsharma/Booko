<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- 1. The Starting Theme (System Splash) -->
    <!-- Parent MUST be Theme.SplashScreen to handle background colors correctly -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <!-- Match the background color to your Compose SplashScreen (#F0CDB5) -->
        <item name="windowSplashScreenBackground">#F2C9AD</item>

        <!-- Use the transparent icon to prevent the system icon from "popping" -->
        <item name="windowSplashScreenAnimatedIcon">@drawable/cat_book</item>

        <!-- Theme to switch to after the system splash is dismissed -->
        <item name="postSplashScreenTheme">@style/Theme.Booko</item>
    </style>

    <style name="Theme.Booko" parent="android:Theme.Material.Light.NoActionBar" />
</resources>